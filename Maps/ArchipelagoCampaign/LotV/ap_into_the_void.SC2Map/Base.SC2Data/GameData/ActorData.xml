<?xml version="1.0" encoding="utf-8"?>
<Catalog>
    <CActorUnit id="AP_CommandCenter">
        <!-- Override -->
        <On Terms="Behavior.AP_FakeHyperion.On" Send="Destroy"/>
    </CActorUnit>
    <CActorUnit id="AP_CommandCenterHyperion" parent="TerranBuilding" unitName="AP_CommandCenter">
        <Aliases value="_UnitHuge"/>
        <AcceptedHostedPropTransfers index="Decal" value="0"/>
        <Remove Terms="UnitBirth.AP_CommandCenter" Send="Create"/>
        <Remove Terms="UnitConstruction.AP_CommandCenter.Start" Send="Create"/>
        <HostSiteOps Ops="SOpBankerUnitBuilding"/>
        <Model value="HyperionKorhal"/>
        <BuildModel value="HyperionKorhal"/>
        <DeathArray index="Normal" ModelLink="SJHyperionDeath" SoundLink="Terran_ExplosionLarge" VoiceLink=""/>
        <PlacementModel value="HyperionKorhal"/>
        <PlacementSound value="Terran_BuildingPlacement"/>
        <PortraitModel value="RaynorMarinePortrait"/>
        <TerrainSquibs>
            <MovementDistance value="0.150000,0.150000"/>
            <IdlePeriod value="0.250000,0.500000"/>
            <RangeDown value="5.000000"/>
            <RangeDownFade value="1.000000"/>
            <AttachQuery Methods="AMFilterCenter"/>
            <Visuals TerrainPhysicsMaterial="Water" ActorModel="TerrainSquibHarnessContinuous" ModelLink="WaterRippleMassive3"/>
        </TerrainSquibs>
        <BarOffset value="165"/>
        <BarWidth value="200"/>
        <GroupIcon>
            <Image value="Assets\Textures\Wireframe-Terran-Battlecruiser.dds"/>
        </GroupIcon>
        <HeroIcon value="Assets\Textures\btn-unit-terran-battlecruiser.dds"/>
        <HighlightTooltip value="Unit/Name/AP_CommandCenterHyperion"/>
        <LifeArmorIcon value="Assets\Textures\btn-upgrade-terran-buildingarmor.dds"/>
        <NameOffset value="150"/>
        <SoundArray index="Birth" value="Hyperion-1Birth"/>
        <SoundArray index="Ready" value="Hyperion-1Ready"/>
        <SoundArray index="Help" value="Hyperion-1Help"/>
        <SoundArray index="What" value="Hyperion-1What"/>
        <SoundArray index="Yes" value="Hyperion-1Yes"/>
        <SoundArray index="Attack" value="Hyperion-1Yes"/>
        <SoundArray index="Pissed" value="Hyperion-1Pissed"/>
        <SoundArray index="Movement" value="Hyperion-1Movement"/>
        <SoundArray index="Turning" value="Hyperion-3_Turning"/>
        <SoundArray index="Board" value="Hyperion-3_Board"/>
        <SoundArray index="Click" value="Hyperion-3_Click"/>
        <SoundArray index="ClickError" value="Hyperion-3_ClickError"/>
        <SoundArray index="Highlight" value="Hyperion-3_Highlight"/>
        <StatusHarvesterData Text="UI/HarvesterCountMinerals" SearchFilters="HarvestableResource;Player,Ally,Enemy" SearchRadius="8"/>
        <UnitIcon value="Assets\Textures\btn-unit-terran-battlecruiser.dds"/>
        <Wireframe>
            <Image value="Assets\Textures\Wireframe-Terran-Battlecruiser.dds"/>
        </Wireframe>
        <On Terms="Behavior.AP_FakeHyperion.On" Send="Create"/>
    </CActorUnit>
    <CActorUnit id="AP_Mira" parent="GenericUnitMinimal" unitName="AP_Mira">
        <On Terms="ActorCreation" Send="AnimPlay Lifetime HappyEyes PlayForever,ForceLooping"/>
        <HostSiteOps Ops="SOpForwardSouth"/>
        <Scale value="20.000000"/>
    </CActorUnit>
    <CActorModel id="AP_SpawningPoolHealAttachmentUltra" parent="ModelAdditionNoAnims">
        <Inherits index="BaseModelScale" value="0"/>
        <Inherits index="Opacity" value="0"/>
        <Inherits index="Scale" value="0"/>
        <Inherits index="Visibility" value="0"/>
        <On Terms="Behavior.AP_SpawningPoolHeal.On; !ScopeContains AP_SpawningPoolHealAttachment" Send="Create"/>
        <On Terms="ActorCreation" Send="AnimBracketStart BSD Unload Walk Load 0 0.400000 AsTimeScale"/>
        <On Terms="Behavior.AP_SpawningPoolHeal.Off" Send="AnimBracketStop BSD"/>
        <On Terms="UnitBirth.AP_SpawningPool.EditorPlaced" Send="Create"/>
        <On Terms="AnimBracketState.*.AfterClosing; AnimName BSD" Send="Destroy"/>
        <On Terms="ActorCreation" Target="_Selectable" Send="ModelSwap SpawningPoolDeath"/>
        <On Terms="ActorCreation" Target="_Selectable" Send="$Death 0 -1.000000 -1.000000 0.800000 AsTimeScale"/>
        <On Terms="ActorCreation" Target="_Selectable" Send="SetScale 1.800000,1.800000,1.500000 1.000000"/>
        <On Terms="ActorCreation" Send="TimerSet 1.000000 Start"/>
        <On Terms="TimerExpired; TimerName Start" Target="_Selectable" Send="ModelSwap SpawningPool"/>
        <On Terms="TimerExpired; TimerName Start" Target="_Selectable" Send="AnimClear Death"/>
        <On Terms="TimerExpired; TimerName Start" Target="_Selectable" Send="SetScale 2.000000,2.000000,1.500000"/>
        <On Terms="TimerExpired; TimerName Start" Target="_Selectable" Send="AnimPlay AP_Work Stand,Work PlayForever,ForceLooping"/>
        <On Terms="ActorDestruction" Target="_Selectable" Send="SetScale 1.000000 1.000000"/>
        <On Terms="ActorDestruction" Target="_Selectable" Send="AnimClear AP_Work"/>
        <On Terms="ActorCreation" Send="TimerSet 4.000000 dive"/>
        <On Terms="TimerExpired; TimerName dive" Send="TimerSet 10.000000 dive"/>
        <On Terms="TimerExpired; TimerName dive" Send="AnimBracketStart AP_Dive Burrow {} Unburrow ContentPlayOnce"/>
        <On Terms="ActorDestruction" Target="_Selectable" Send="ModelSwap SpawningPool"/>
        <On Terms="TimerExpired; TimerName Start" Target="AP_SpawningPoolHydralisk" Send="Destroy"/>
        <On Terms="TimerExpired; TimerName Start" Target="AP_SpawningPoolZergling" Send="Destroy"/>
        <HostSiteOps Ops="SOpAttachOrigin SOp180"/>
        <Model value="Ultralisk"/>
    </CActorModel>
    <CActorSiteOpRotator id="AP_SpawningPoolZerglingRotator">
        <LocalAxis value="0.000000,0.000000,-1.000000"/>
        <Rate value="100.000000"/>
    </CActorSiteOpRotator>
    <CActorModel id="AP_SpawningPoolZergling" parent="ModelAdditionNoAnims">
        <Inherits index="BaseModelScale" value="0"/>
        <Inherits index="Opacity" value="0"/>
        <Inherits index="Scale" value="0"/>
        <On Terms="ActorCreation" Send="AnimBracketStart BSD Birth Walk,01 Death"/>
        <On Terms="AnimBracketState.*.AfterClosing; AnimName BSD" Send="Destroy"/>
        <HostSiteOps Ops="SOpMoveUpByDot25 AP_SpawningPoolZerglingRotator SOpMoveBackByDot5 SOp90"/>
        <Model value="ZerglingXPR"/>
        <Scale value="0.700000"/>
    </CActorModel>
    <CActorModel id="AP_SpawningPoolHydralisk" parent="ModelAdditionNoAnims">
        <Inherits index="BaseModelScale" value="0"/>
        <Inherits index="Opacity" value="0"/>
        <Inherits index="Scale" value="0"/>
        <On Terms="ActorCreation" Send="AnimBracketStart BSD Unburrow Dance,00 Burrow ContentPlayOnce"/>
        <On Terms="ActorCreation" Target="_Selectable" Send="SetScale 1.500000,1.500000,0.900000"/>
        <On Terms="AnimBracketState.*.AfterClosing" Send="AnimBracketStart Death Unburrow Walk,00 Burrow OpeningPlayForever"/>
        <On Terms="ActorCreation" Send="Create AP_SpawningPoolZergling"/>
        <On Terms="ActorCreation; IsInEditor" Send="TimerSet 5.000000"/>
        <On Terms="TimerExpired; IsInEditor" Send="Create AP_SpawningPoolHealAttachmentUltra"/>
        <HostSiteOps Ops="SOpMoveUpByDot25"/>
        <Model value="Hydralisk"/>
        <Scale value="0.800000"/>
    </CActorModel>
    <CActorModel id="WarpInVoid">
        <!-- Override -->
        <On Terms="Abil.StargateWarpTrainAI.TargetStop" Send="AnimBracketStop BSD"/>
    </CActorModel>
</Catalog>
