<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<Desc>
    <Frame type="CommandButton" name="TerranCommandButtonTemplate" template="CommandButton/CommandButtonTemplate">
        <Width val="60"/>
        <Height val="60"/>
        <TooltipFrame val="TerranCommandTooltip"/>
        <ClickSound val="*@UI_SoA_SpellClick"/>
        <!--HotkeyUse val="CommanderAbility0"/-->
        <Frame type="CommandHotkeyFrame" name="HotkeyFrame">
            <Frame type="Label" name="HotkeyLabel">
                <Visible val="false"/>
            </Frame>
            <Frame type="Image" name="HotkeyLabelBackground">
                <Visible val="false"/>
            </Frame>
        </Frame>
    </Frame>

    <Frame type="Image" name="TerranLockedImageTemplate">
        <!--Anchor relative="$parent/CommandButton00"/-->
        <Texture val="AP\Assets\Textures\ui_terran_topbar_ability_lock.dds"/>
        <StateGroup name="Visibility">
            <DefaultState val="Visible"/>
            <State name="NotVisible">
                <!--When type="Property" frame="$parent/CommandButton00" Visible="True"/-->
                <Action type="SetProperty" frame="$this" Visible="False"/>
            </State>
            <State name="Visible"></State>
        </StateGroup>
    </Frame>     

    <Frame type="CommandButton" name="ZergCommandButtonTemplate" template="CommandButton/CommandButtonTemplate">
        <Width val="60"/>
        <Height val="60"/>
        <TooltipFrame val="TerranCommandTooltip"/>
        <ClickSound val="*@UI_SoA_SpellClick"/>
        <!--HotkeyUse val="CommanderAbility0"/-->
        <Frame type="CommandHotkeyFrame" name="HotkeyFrame">
            <Frame type="Label" name="HotkeyLabel">
                <Visible val="false"/>
            </Frame>
            <Frame type="Image" name="HotkeyLabelBackground">
                <Visible val="false"/>
            </Frame>
        </Frame>
    </Frame>

    <Frame type="Image" name="ZergLockedImageTemplate">
        <!--Anchor relative="$parent/CommandButton00"/-->
        <Texture val="AP\Assets\Textures\ui_zerg_topbar_ability_lock.dds"/>
        <StateGroup name="Visibility">
            <DefaultState val="Visible"/>
            <State name="NotVisible">
                <!--When type="Property" frame="$parent/CommandButton00" Visible="True"/-->
                <Action type="SetProperty" frame="$this" Visible="False"/>
            </State>
            <State name="Visible"></State>
        </StateGroup>
    </Frame>     

    <Frame type="CommandPanel" name="TerranGlobalCommandPanelTemplate" template="CommandPanel/CommandPanelTemplate">
        <Width val="688"/>
        <Height val="700"/>
        <Handle val="ap_TerranGlobalCommandPanel"/>
        <Animation name="FadeIn">
            <Event event="OnShown" action="Reset"/>
            <Event event="OnShown" action="Play"/>                
            <Controller type="Fade" end="Pause">
                <Key type="Curve" time="0" value="0" out="Slow"/>
                <Key type="Curve" time="0.25" value="255" in="Slow"/>
            </Controller>
        </Animation>
        
        <Anchor side="Top" relative="$parent" pos="Min" offset="1"/>
        <Anchor side="Left" relative="$parent" pos="Min" offset="0"/>
        <HideUnusedButtons val="true"/>
        <DisplayCancelCommandCard val="false"/>
        <UseGridHotkeys val="false"/>

        <Frame type="CommandTooltip" name="TerranCommandTooltip" template="CommandButton/CommandTooltipTemplate">
            <Anchor side="Top" relative="$parent" pos="Min" offset="120"/>
            <Anchor side="Left" relative="$parent" pos="Mid" offset="-225"/>
        </Frame>

        <Frame type="UnitStatusFrame" name="TerranTopbarStatusFrame">
            <Anchor side="Top" relative="$parent" pos="Min" offset="60"/>
            <Anchor side="Bottom" relative="$this" pos="Min" offset="0"/>
            <Anchor side="Left" relative="$this" pos="Max" offset="0"/>
            <Anchor side="Right" relative="$parent" pos="Mid" offset="250"/>
            <Height val="100"/>
            <Width val="500"/>
            <Frame type="Image" name="TerranTopbarStatusBackground">
                <Anchor side="Top" relative="$parent" pos="Min" offset="0"/>
                <Anchor side="Left" relative="$parent" pos="Mid" offset="0"/>
                <Anchor side="Right" relative="$parent" pos="Mid" offset="0"/>
                <Height val="40"/>
                <Width val="500"/>
                <Texture val="Assets\Textures\terran-border-tech.dds"/>
                <TextureType val="Border"/>
                <RenderPriority val="500"/>
                <RenderType val="HDR"/>
            </Frame>

            <Frame type="UnitStatusEnergyBar" name="EnergyBar" template="AP_LotV_UnitStatus/UnitStatusEnergyBarTemplate" >
                <Anchor side="Top" relative="$parent" pos="Min" offset="10"/>
                <Anchor side="Left" relative="$parent" pos="Mid" offset="0"/>
                <Anchor side="Right" relative="$parent" pos="Mid" offset="0"/>
                <Height val="20"/>
                <Width val="450"/>
                <OwnerColor val="ffa600"/>
                <IncreaseDuration val="0"/>
                <DecreaseDuration val="2000"/>
                <Frame type="UnitStatusEnergyLabel" name="UnitStatusEnergyLabel">
                    <Anchor side="Top" relative="$parent" pos="Min" offset="0"/>
                    <Anchor side="Bottom" relative="$parent" pos="Max" offset="0"/>
                    <Anchor side="Left" relative="$parent" pos="Mid" offset="0"/>
                    <Anchor side="Right" relative="$parent" pos="Mid" offset="0"/>
                    <Height val="25"/>
                    <Frame type="Label" name="StatusLabel">
                        <Anchor side="Top" relative="$parent" pos="Min" offset="0"/>
                        <Anchor side="Bottom" relative="$parent" pos="Max" offset="0"/>
                        <Anchor side="Left" relative="$parent" pos="Mid" offset="0"/>
                        <Anchor side="Right" relative="$parent" pos="Mid" offset="0"/>
                        <Options val="NoWrapping | ScaleToPreventTruncation"/>
                        <Style val="BossBarHP"/>
                    </Frame>
                </Frame>
            </Frame>
        </Frame>
        <Frame type="CommandButton" name="CommandButton00" template="ap_topbars/TerranCommandButtonTemplate">
            <Anchor side="Top" relative="$parent" pos="Min" offset="8"/>
            <Anchor side="Bottom" relative="$this" pos="Min" offset="0"/>
            <Anchor side="Left" relative="$this" pos="Max" offset="0"/>
            <Anchor side="Right" relative="$parent" pos="Mid" offset="-205"/>   
