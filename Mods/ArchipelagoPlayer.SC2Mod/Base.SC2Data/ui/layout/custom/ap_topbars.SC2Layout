    <Frame type="Frame" name="GameUI/UIContainer/FullscreenUpperContainer" file="GameUI">
        <Frame type="Frame" name="TerranCasterVisibilityButtonContainer">
            <Handle val="ap_TerranCasterVisibilityButtonContainer"/>
            <Anchor side="Top" relative="$parent" pos="Min" offset="0"/>
            <Anchor side="Bottom" relative="$this" pos="Min" offset="0"/>
            <Anchor side="Right" relative="$parent" pos="Mid" offset="0"/>
            <Anchor side="Left" relative="$parent" pos="Mid" offset="0"/>
            <Height val="200"/>
            <Width val="500"/>
            <Frame type="Button" name="HideButton" template="TriggerDialogFrame/TriggerControlButtonTemplate">
                <Anchor side="Top" relative="$parent" pos="Min" offset="130"/>
                <Anchor side="Right" relative="$parent" pos="Mid" offset="0"/>
                <Anchor side="Left" relative="$parent" pos="Mid" offset="0"/>
                <Width val="28"/>
                <Height val="30"/>
                <Tooltip val="Hide"/>
                <Visible val="False"/>
                <RenderPriority val="1000"/>
                <Frame type="Image" name="NormalImage">
                    <Anchor relative="$parent"/>
                    <TextureType val="normal"/>
                    <Texture val="AP\Assets\Textures\ui-terrantopbar-normal.dds"/>
                </Frame>
                <Frame type="Image" name="HoverImage">
                    <Anchor relative="$parent"/>
                    <TextureType val="normal"/>
                    <Texture val="AP\Assets\Textures\ui-terrantopbar-hover.dds"/>
                </Frame>
                <Animation name="FadeIn">
                    <Event event="OnShown" action="Reset"/>
                    <Event event="OnShown" action="Play"/>                
                    <Controller type="Fade" end="Pause">
                        <Key type="Curve" time="0" value="0" out="Slow"/>
                        <Key type="Curve" time="0.25" value="255" in="Slow"/>
                    </Controller>
                </Animation>
            </Frame>
            <Frame type="Button" name="ShowButton" template="TriggerDialogFrame/TriggerControlButtonTemplate">
                <Anchor side="Top" relative="$parent" pos="Min" offset="-10"/>
                <Anchor side="Right" relative="$parent" pos="Mid" offset="0"/>
                <Anchor side="Left" relative="$parent" pos="Mid" offset="0"/>
                <Width val="28"/>
                <Height val="30"/>
                <Visible val="false"/>
                <Tooltip val="Show"/>
                <Frame type="Image" name="NormalImage">
                    <Anchor relative="$parent"/>
                    <TextureType val="normal"/>
                    <Rotation val="180"/>
                    <Texture val="AP\Assets\Textures\ui-terrantopbar-normal.dds"/>
                </Frame>                
                <Frame type="Image" name="HoverImage">
                    <Anchor relative="$parent"/>
                    <TextureType val="normal"/>
                    <Rotation val="180"/>
                    <Texture val="AP\Assets\Textures\ui-terrantopbar-hover.dds"/>
                </Frame>
                <Animation name="FadeIn">
                    <Event event="OnShown" action="Reset"/>
                    <Event event="OnShown" action="Play"/>                
                    <Controller type="Fade" end="Pause">
                        <Key type="Curve" time="0" value="0" out="Slow"/>
                        <Key type="Curve" time="0.25" value="255" in="Slow"/>
                    </Controller>
                </Animation>
            </Frame>
        </Frame>
    </Frame>

    <Frame type="CommandPanel" name="ZergGlobalCommandPanelTemplate" template="CommandPanel/CommandPanelTemplate">
        <Width val="688"/>
        <Height val="700"/>
        
        <Anchor side="Top" relative="$parent" pos="Min" offset="1"/>
        <Anchor side="Left" relative="$parent" pos="Min" offset="0"/>
        <HideUnusedButtons val="true"/>
        <DisplayCancelCommandCard val="false"/>
