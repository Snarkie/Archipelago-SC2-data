// Trigger: AP_Core_showChatboxCinematic
//--------------------------------------------------------------------------------------------------
bool lib5BD4895D_gt_AP_Core_showChatboxCinematic_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_indexPlayer;

    // Automatic Variable Declarations
    playergroup autoEF928640_g;

    // Variable Initialization

    // Conditions
    if (testConds) {
        if (!((GameGetMissionTime() >= 2.0))) {
            return false;
        }

        if (!((lib5BD4895D_gv_aP_Core_initFinished == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    autoEF928640_g = PlayerGroupActive();
    lv_indexPlayer = -1;
    while (true) {
        lv_indexPlayer = PlayerGroupNextPlayer(autoEF928640_g, lv_indexPlayer);
        if (lv_indexPlayer < 0) { break; }
        if ((PlayerType(lv_indexPlayer) != c_playerTypeUser)) {
            break;
        }

        if ((libNtve_gf_PlayerInCinematicMode(lv_indexPlayer) == false)) {
            lib5BD4895D_gf_AP_Core_showHideChatbox(lv_indexPlayer, true);
            TriggerEnable(TriggerGetCurrent(), false);
        }

    }
    return true;
}

